# RichesReach Mobile App Environment Configuration
# Copy this file to mobile/.env and update the values for your environment

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Main API Base URL (required)
# Simulator: http://localhost:8000
# Physical device: use your computer's LAN IP (backend must be running and reachable)
#   Get IP: ipconfig getifaddr en0  → then http://YOUR_IP:8000
# Production: https://api.richesreach.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: override fallback LAN IP for physical device (when API_BASE_URL not used)
# Must match the machine running the backend. Get IP: ipconfig getifaddr en0
# EXPO_PUBLIC_LAN_IP=192.168.1.246

# Alternative API URL (for specific components)
EXPO_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# WEBSOCKET CONFIGURATION
# =============================================================================

# WebSocket URL for real-time features
EXPO_PUBLIC_WS_URL=ws://localhost:8000/ws/

# =============================================================================
# STREAMING SERVICES
# =============================================================================

# SFU Server URL for live streaming
EXPO_PUBLIC_SFU_SERVER_URL=http://localhost:8000

# Whisper API URL for voice transcription
EXPO_PUBLIC_WHISPER_API_URL=http://localhost:3001

# =============================================================================
# BLOCKCHAIN SERVICES
# =============================================================================

# WalletConnect Project ID (required for wallet connect to work)
# The placeholder above is invalid; get a free Project ID at https://cloud.walletconnect.com
# Without a valid ID you'll see: WebSocket closed 3000 (Unauthorized: invalid key)
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_from_cloud_walletconnect

# Alchemy API URLs
EXPO_PUBLIC_ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/2-rJhszNwQ6I3NuBdN5pz
EXPO_PUBLIC_ALCHEMY_POLYGON_URL=uuKmy9dPAjaSVXVEtCumQPga1dqEPDS2

# =============================================================================
# NEWS / CONTENT
# =============================================================================

# NewsAPI.org key for news feed (optional; app has fallback key for development)
# EXPO_PUBLIC_NEWS_API_KEY=your_newsapi_key

# =============================================================================
# COMMUNICATION SERVICES
# =============================================================================

# Agora App ID for voice/video
EXPO_PUBLIC_AGORA_APP_ID=2d220d40a19d4fea955d4aac662b24d1

# GetStream.io keys
EXPO_PUBLIC_STREAM_API_KEY=4866mbx8b4jv

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Enable debug logging
EXPO_PUBLIC_DEBUG=true

# Enable mock data mode
EXPO_PUBLIC_USE_MOCK_DATA=false

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================

# Production API URL (uncomment for production)
# EXPO_PUBLIC_API_BASE_URL=https://api.richesreach.com
# EXPO_PUBLIC_API_URL=https://api.richesreach.com
# EXPO_PUBLIC_WS_URL=wss://api.richesreach.com/ws/
# EXPO_PUBLIC_SFU_SERVER_URL=https://api.richesreach.com
# EXPO_PUBLIC_WHISPER_API_URL=https://api.richesreach.com
